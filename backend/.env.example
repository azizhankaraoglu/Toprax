# TabSIS Backend — Ortam Değişkenleri Örneği
# Bu dosyayı ".env" olarak kopyalayıp değerleri doldurun.

# development | production — production iken JWT_SECRET/PLATFORM_ADMIN_PASSWORD
# zorunlu hale gelir (varsayılan/boş değerle açılış RuntimeError ile reddedilir)
# ve demo seed uçları (/admin/seed*) ALLOW_DATA_SEEDING=true verilmedikçe kapalıdır.
ENVIRONMENT=development

MONGO_URL=mongodb://localhost:27017
DB_NAME=tarim_kooperatif

# ÜRETİMDE MUTLAKA değiştirin! Güçlü, rastgele bir değer kullanın.
# Örnek üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=DEGISTIR-guclu-ve-rastgele-bir-deger

# /admin/seed, /admin/seed-extras, /admin/seed-forms uçlarını açar/kapatır.
# Boş bırakılırsa: development'ta açık, production'da kapalı (fail-closed).
ALLOW_DATA_SEEDING=true

# Frontend'in çalıştığı domain(ler) — virgülle ayırın. Üretimde sadece
# kendi domain'inizi yazın, "*" KULLANMAYIN.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Platform admin — tenant'ları (kooperatifleri) oluşturup yönetir.
# İlk açılışta bu bilgilerle otomatik oluşturulur. ÜRETİMDE DEĞİŞTİRİN.
PLATFORM_ADMIN_EMAIL=platform@tabsis.local
PLATFORM_ADMIN_PASSWORD=DEGISTIR-guclu-bir-sifre

# Integration Center (SMS/Email/Planet Labs/AI) varsayılan bağlantı zaman
# aşımı (saniye) ve başarısız denemede kaç kez tekrar denenecek. Her
# entegrasyon için admin panelden ayrıca override edilebilir; burada
# tanımlı olmayanlar bu varsayılanı kullanır.
INTEGRATION_TIMEOUT_SECONDS=10
INTEGRATION_RETRY_COUNT=1
