# TabSIS — docker-compose Ortam Değişkenleri Örneği
# Bu dosyayı ".env" olarak (docker-compose.yml ile AYNI dizine) kopyalayıp
# değerleri doldurun. docker-compose bu değişkenler olmadan (production
# varsayılanıyla) AÇILMAZ — fail-fast, bkz. docker-compose.yml notları.

# development | production. production'da backend içindeki config_service.py
# aşağıdaki secret'lar boş/varsayılan ise açılışta RuntimeError fırlatır.
ENVIRONMENT=production

# Mongo kimlik doğrulaması — ARTIK ZORUNLU (P0 güvenlik düzeltmesi öncesi
# Mongo hem host'a açık hem kimlik doğrulamasızdı).
MONGO_ROOT_USERNAME=tabsis_admin
MONGO_ROOT_PASSWORD=DEGISTIR-guclu-ve-rastgele-bir-mongo-sifresi

# Güçlü, rastgele bir değer kullanın. Örnek üretmek için:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=DEGISTIR-guclu-ve-rastgele-bir-deger

# Platform admin — tenant'ları (kooperatifleri) oluşturup yönetir.
# İlk açılışta bu bilgilerle otomatik oluşturulur.
PLATFORM_ADMIN_EMAIL=platform@tabsis.local
PLATFORM_ADMIN_PASSWORD=DEGISTIR-guclu-bir-sifre

# /admin/seed, /admin/seed-extras, /admin/seed-forms uçlarını açar/kapatır.
# production'da varsayılan kapalıdır (fail-closed) — demo veri yüklemek
# isteyen bir staging/deneme ortamında elle "true" yapın.
ALLOW_DATA_SEEDING=false

# Frontend'in çalıştığı domain(ler) — virgülle ayırın. "*" KULLANMAYIN.
CORS_ORIGINS=https://your-domain.example.com

# PR-12 (opsiyonel) — hata izleme (Sentry veya self-hosted GlitchTip DSN'i).
# Boş bırakılırsa tamamen devre dışı kalır, hiçbir davranış değişmez.
SENTRY_DSN=
